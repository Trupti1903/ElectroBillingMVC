<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElectroBillingMVC</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ElectroBillingMVC.styles.css" asp-append-version="true" />

    <style>
        /* Header Design */
        .navbar {
            background-color: #2c3e50 !important;
            padding: 14px 30px;
            box-shadow: 0 3px 8px rgba(0,0,0,0.3);
        }

        .navbar-brand {
            color: white !important;
            font-size: 22px;
            font-weight: 500;
        }

        .nav-link {
            color: white !important;
        }

            .nav-link:hover {
                color: #f1f1f1 !important;
            }
        /* Footer Style */
        .footer-custom {
            background-color: #1f2d3d;
            color: white;
            text-align: center;
            padding: 18px 0;
        }

            .footer-custom a {
                color: white;
                margin: 0 20px;
                text-decoration: none;
                font-weight: 500;
            }

                .footer-custom a:hover {
                    text-decoration: underline;
                }

        .footer-copy {
            margin-top: 6px;
            font-size: 14px;
            color: #dcdcdc;
        }


        /* Logout Button Style */
        .logout-btn {
            background-color: #e74c3c;
            color: white !important;
            padding: 6px 18px;
            border-radius: 8px;
            text-decoration: none;
        }

            .logout-btn:hover {
                background-color: #c0392b;
            }

        /* Make toggler icon white */
        .navbar-toggler-icon {
            filter: invert(1);
        }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-3">
            <div class="container-fluid">

                <!-- Left Side Logo -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    Electronic Shop
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Right Side Menu -->
                <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">

                    <ul class="navbar-nav align-items-center">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Billing" asp-action="Create">
                                Billing
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Billing" asp-action="Pending">
                                Pending Payments
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Billing" asp-action="Paid">
                                Paid Payments
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Billing" asp-action="History">
                                Customer History
                            </a>
                        </li>

                        <li class="nav-item ms-3">
                            <a class="logout-btn"
                               asp-controller="Billing"
                               asp-action="Login">
                                Logout
                            </a>
                        </li>

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom">
        <div class="container">

            <div>
                <a asp-controller="Home" asp-action="About">About Us</a>
                <a asp-controller="Home" asp-action="Contact">Contact</a>
                <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            </div>

            <div class="footer-copy">
                © 2026 Electronic Shop. All Rights Reserved.
            </div>

        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
