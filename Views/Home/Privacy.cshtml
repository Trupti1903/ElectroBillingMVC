@{
    ViewBag.Title = "Privacy Policy";
}

<style>
    body {
        background-color: #e9ecef;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .privacy-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 0;
    }

    .privacy-card {
        width: 800px;
        background: linear-gradient(135deg, #0f1b2e, #1c2b45);
        color: #ffffff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .privacy-title {
        text-align: center;
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .privacy-subtitle {
        text-align: center;
        color: #cfd8e3;
        margin-bottom: 30px;
    }

    .policy-box {
        background-color: rgba(255,255,255,0.05);
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 20px;
        border: 1px solid rgba(255,255,255,0.08);
    }

        .policy-box h4 {
            margin-bottom: 10px;
            font-weight: 600;
        }

        .policy-box ul {
            padding-left: 20px;
        }

        .policy-box li {
            margin-bottom: 5px;
        }
</style>

<div class="privacy-container">
    <div class="privacy-card">

        <div class="privacy-title">Privacy Policy</div>
        <p class="privacy-subtitle">
            Your privacy matters to us. This page explains how we collect, use, and protect your personal information in the
            <b>Electronic Shop Billing System</b>.
        </p>

        <div class="policy-box">
            <h4>1. Information We Collect</h4>
            <p>
                We may collect personal information including your name, email, contact number, and billing details to provide a seamless shopping and billing experience. This information helps us improve services and personalize your experience.
            </p>
        </div>

        <div class="policy-box">
            <h4>2. How We Use Your Information</h4>
            <p>Collected information is used solely for:</p>
            <ul>
                <li>Processing orders and generating invoices</li>
                <li>Managing customer accounts and purchase history</li>
                <li>Improving application features and usability</li>
            </ul>
            <p><b>We do not share your personal data with third parties.</b></p>
        </div>

        <div class="policy-box">
            <h4>3. Data Security</h4>
            <p>
                Your data is stored securely on your device using local storage. We implement best practices to prevent unauthorized access and protect your information.
            </p>
        </div>

        <div class="policy-box">
            <h4>4. Changes to This Policy</h4>
            <p>
                We may update this Privacy Policy periodically. Any changes will be reflected on this page. We encourage you to review it regularly.
            </p>
        </div>

        <div class="policy-box">
            <h4>5. Your Consent</h4>
            <p>
                By using the <b>Electronic Shop Billing System</b>, you agree to the terms outlined in this Privacy Policy.
            </p>
        </div>

    </div>
</div>
