@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            background: linear-gradient(to right, #162a45, #243b55);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* HEADER */
        .header {
            background-color: #2c3e50;
            color: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
        }

        .header-title {
            font-size: 22px;
            font-weight: 500;
        }

        .logout-btn {
            background-color: #e74c3c;
            color: white;
            padding: 6px 18px;
            border-radius: 6px;
            text-decoration: none;
        }

            .logout-btn:hover {
                background-color: #c0392b;
                color: white;
            }

        /* MAIN CONTENT */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .title-section {
            text-align: center;
            color: white;
            margin-top: 40px;
        }

            .title-section h1 {
                font-size: 36px;
                font-weight: 500;
            }

            .title-section p {
                font-size: 16px;
                color: #dcdcdc;
            }

        .dashboard-wrapper {
            margin-top: 50px;
            margin-bottom: 80px;
            width: 900px;
        }

        .dashboard-card {
            background-color: #e6e6e6;
            border-radius: 20px;
            height: 180px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            transition: 0.3s;
        }

            .dashboard-card:hover {
                transform: translateY(-6px);
            }

            .dashboard-card h3 {
                margin-bottom: 8px;
            }

            .dashboard-card p {
                font-size: 14px;
                color: #444;
            }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* FOOTER */
        .footer {
            background-color: #1f2d3d;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: auto;
        }

        .footer-links a {
            color: white;
            margin: 0 15px;
            text-decoration: none;
        }

            .footer-links a:hover {
                text-decoration: underline;
            }

        .footer-copy {
            margin-top: 5px;
            font-size: 14px;
            color: #ccc;
        }

    </style>

</head>
<body>

    <!-- HEADER -->
    <div class="header">

        <div class="header-title">
            Electronic Shop
        </div>

        <a asp-controller="Account"
           asp-action="Logout"
           class="logout-btn">
            Logout
        </a>

    </div>


    <!-- MAIN CONTENT -->
    <div class="main-content">

        <div class="title-section">
            <h1>Manager Dashboard</h1>
            <p>Electronic Shop Billing System</p>
        </div>


        <div class="dashboard-wrapper">

            <div class="row g-5">

                <div class="col-md-6">
                    <a asp-controller="Billing" asp-action="Create">
                        <div class="dashboard-card">
                            <h3>Billing</h3>
                            <p>Create customer bills</p>
                        </div>
                    </a>
                </div>


                <div class="col-md-6">
                    <a asp-controller="Billing" asp-action="History">
                        <div class="dashboard-card">
                            <h3>Customer History</h3>
                            <p>Payment history of customers</p>
                        </div>
                    </a>
                </div>


                <div class="col-md-6">
                    <a asp-controller="Billing" asp-action="Pending">
                        <div class="dashboard-card">
                            <h3>Pending Payments</h3>
                            <p>View due amounts</p>
                        </div>
                    </a>
                </div>


                <div class="col-md-6">
                    <a asp-controller="Billing" asp-action="Paid">
                        <div class="dashboard-card">
                            <h3>Paid Payments</h3>
                            <p>View completed payments</p>
                        </div>
                    </a>
                </div>

            </div>

        </div>

    </div>


    <!-- FOOTER -->
    <div class="footer">

        <div class="footer-links">
            <a asp-controller="Home" asp-action="About">About Us</a>
            <a href="#">Contact</a>
            <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>

        <div class="footer-copy">
            © 2026 Electronic Shop. All Rights Reserved.
        </div>

    </div>


</body>
</html>
