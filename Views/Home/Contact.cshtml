@{
    ViewData["Title"] = "Contact";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .contact-container {
        max-width: 800px;
        margin: 40px auto;
        text-align: center;
    }

    .contact-box {
        background-color: #f2f2f2;
        padding: 25px;
        border-radius: 8px;
        text-align: left;
        margin-top: 20px;
    }

        .contact-box p {
            margin: 10px 0;
            font-size: 16px;
        }

    .working-hours {
        margin-top: 40px;
        text-align: left;
    }

    h1 {
        margin-bottom: 10px;
    }
</style>

<div class="contact-container">
    <h1>Contact Us</h1>

    <p>
        If you have any questions, suggestions, or need support regarding
        <b>ElectroBilling</b>, feel free to contact us.
    </p>

    <div class="contact-box">
        <p><b>Shop Name:</b> ElectroBilling Electronic Shop</p>
        <p><b>Email:</b> support@electrobilling.com</p>
        <p><b>Phone:</b> +91 98765 43210</p>
        <p><b>Address:</b> Rajkot, Gujarat, India</p>
    </div>

    <div class="working-hours">
        <h2>Working Hours</h2>
        <p>Monday – Saturday: 9:00 AM – 8:00 PM</p>
        <p>Sunday: Closed</p>
    </div>
</div>