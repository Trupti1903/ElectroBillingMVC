@model IEnumerable<ElectroBillingMVC.Models.Bill>

@{
    ViewData["Title"] = "Pending Payments";
}

<style>
    body {
        background: linear-gradient(to right, #1e2f44, #243b55);
        margin: 0;
        padding: 0;
        font-family: Arial, sans-serif;
    }

    .pending-container {
        min-height: 90vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .pending-card {
        background: #ffffff;
        padding: 30px;
        border-radius: 12px;
        width: 100%;
        max-width: 900px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
    }

        .pending-card h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #2c3e50;
        }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #2c3e50;
        color: white;
        padding: 12px;
        text-align: center;
        font-size: 15px;
    }

    td {
        padding: 12px;
        text-align: center;
        border: 1px solid #ddd;
        color: #333;
        font-size: 14px;
    }

    tr:nth-child(even) {
        background-color: #f2f2f2;
    }

    .receive-btn {
        background-color: #28a745;
        color: white;
        padding: 6px 14px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }

        .receive-btn:hover {
            background-color: #218838;
        }

    .no-data {
        text-align: center;
        padding: 20px;
        font-size: 16px;
        color: #888;
    }
</style>

<div class="pending-container">
    <div class="pending-card">
        <h2>Pending Payments</h2>

        <table>
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th>Mobile</th>
                    <th>Pending Amount</th>
                    <th>Bill Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var bill in Model)
                    {
                        <tr>
                            <td>@bill.CustomerName</td>
                            <td>@bill.Phone</td>
                            <td>₹@bill.RemainingAmount</td>
                            <td>@bill.BillDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <form asp-action="ReceivePayment" asp-controller="Billing" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@bill.BillId" />
                                    <button type="submit" class="receive-btn">Receive</button>
                                </form>
                            </td>
                        </tr>
                    <td>
                        <form asp-action="UpdatePayment" asp-controller="Billing" method="post">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="id" value="@bill.BillId" />

                            <input type="number"
                                   name="amount"
                                   min="1"
                                   max="@bill.RemainingAmount"
                                   placeholder="Enter amount"
                                   required
                                   style="width:100px; padding:4px;" />

                            <button type="submit" class="receive-btn">
                                Update
                            </button>
                        </form>
                    </td>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="no-data">No Pending Payments Found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>