@model IEnumerable<ElectroBillingMVC.Models.Bill>

@{
    ViewData["Title"] = "Pending Payments";
}

<style>
    body {
        background: linear-gradient(to right, #1e2f44, #243b55);
    }

    .pending-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 85vh;
    }

    .pending-card {
        background: #f2f2f2;
        padding: 40px;
        border-radius: 15px;
        width: 650px;
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    }

        .pending-card h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #222;
        }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #2c3e50;
        color: white;
        padding: 12px;
        text-align: center;
    }

    td {
        padding: 12px;
        text-align: center;
        border: 1px solid #ccc;
        color: #333;
    }

    .receive-btn {
        background-color: #4a8af4;
        color: white;
        padding: 6px 14px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }

        .receive-btn:hover {
            background-color: #3b73cc;
        }
</style>

<div class="pending-container">
    <div class="pending-card">
        <h2>Pending Payments</h2>

        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Mobile</th>
                    <th>Pending</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Yashvi</td>
                    <td>123456790</td>
                    <td>₹60</td>
                    <td>
                        <button class="receive-btn">Receive</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
