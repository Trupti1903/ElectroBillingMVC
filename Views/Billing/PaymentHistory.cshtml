@model IEnumerable<ElectroBillingMVC.Models.Bill>

@{
    ViewData["Title"] = "Payment History";
    var firstBill = Model.FirstOrDefault();
}

<style>
    body {
        background-color: #f4f6f9;
    }

    .page-container {
        padding: 30px;
    }

    .back-btn {
        background-color: #4e73df;
        color: white;
        border: none;
        padding: 6px 15px;
        margin-bottom: 15px;
        text-decoration: none;
        border-radius: 5px;
    }

    .info-card {
        background-color: #e9ecef;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .table-container {
        background: white;
        border-radius: 10px;
        padding: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
</style>

<div class="container page-container">

    <a asp-controller="Billing"
       asp-action="History"
       class="back-btn">
        ← Back to Customers
    </a>

    @if (firstBill != null)
    {
        <h2>@firstBill.CustomerName – Payment History</h2>

        <!-- Customer Info -->
        <div class="info-card">
            <p><b>Customer Name:</b> @firstBill.CustomerName</p>
            <p><b>Mobile Number:</b> @firstBill.Phone</p>
            <p><b>Address:</b> @firstBill.Address</p>
        </div>

        <!-- Payment Table -->
        <div class="table-container">
            <table class="table table-bordered">
                <thead class="table-secondary">
                    <tr>
                        <th>#</th>
                        <th>Total Amount</th>
                        <th>Paid Amount</th>
                        <th>Remaining</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int count = 1;
                    }
                    @foreach (var bill in Model)
                    {
                        <tr>
                            <td>@count</td>
                            <td>₹@bill.TotalAmount</td>
                            <td>₹@bill.PaidAmount</td>
                            <td>₹@bill.RemainingAmount</td>
                            <td>@bill.Status</td>
                            <td>@bill.BillDate.ToString("dd/MM/yyyy hh:mm tt")</td>
                        </tr>

                        count++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p>No records found.</p>
    }

</div>