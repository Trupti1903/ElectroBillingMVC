@model ElectroBillingMVC.Models.Bill

@{
    ViewData["Title"] = "Payment History";
}

<style>
    body {
        background-color: #f4f6f9;
    }

    .page-container {
        padding: 30px;
    }

    .back-btn {
        background-color: #4e73df;
        color: white;
        border: none;
        padding: 6px 15px;
        margin-bottom: 15px;
        text-decoration: none;
        border-radius: 5px;
    }

    .info-card {
        background-color: #e9ecef;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .table-container {
        background: white;
        border-radius: 10px;
        padding: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    footer {
        background: #1e2a38;
        color: white;
        text-align: center;
        padding: 15px;
        margin-top: 40px;
    }
</style>

<div class="container page-container">

    <!-- Back Button -->
    <a asp-controller="Billing"
       asp-action="History"
       class="back-btn">
        ← Back to Customers
    </a>

    <!-- Page Title -->
    <h2>@Model.CustomerName – Payment History</h2>

    <!-- Customer Info -->
    <div class="info-card">
        <p><b>Customer Name:</b> @Model.CustomerName</p>
        <p><b>Mobile Number:</b> @Model.Phone</p>
        <p><b>Total Bill Amount:</b> ₹@Model.TotalAmount</p>
        <p><b>Total Paid:</b> ₹@Model.PaidAmount</p>
        <p><b>Current Pending:</b> ₹@Model.RemainingAmount</p>
        <p><b>Status:</b> @Model.Status</p>
    </div>

    <!-- Payment Table -->
    <div class="table-container">
        <table class="table table-bordered">
            <thead class="table-secondary">
                <tr>
                    <th>#</th>
                    <th>Paid Amount</th>
                    <th>Pending After Bill</th>
                    <th>Date</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>₹@Model.PaidAmount</td>
                    <td>₹@Model.RemainingAmount</td>
                    <td>@Model.BillDate.ToString("dd/MM/yyyy")</td>
                    <td>@Model.BillDate.ToString("hh:mm tt")</td>
                    <td>
                        <a asp-controller="Billing"
                           asp-action="DeletePayment"
                           asp-route-id="@Model.BillId"
                           class="btn btn-danger"
                           onclick="return confirm('Are you sure you want to delete this payment?');">
                            Delete
                        </a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>