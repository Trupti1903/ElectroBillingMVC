@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Electro Billing</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, Helvetica, sans-serif;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(to right, #4b1c53, #b03a6b);
        }

        .card {
            background: #e6e6e6;
            padding: 50px;
            width: 350px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            text-align: center;
        }

        .icon {
            font-size: 28px;
        }

        h1 {
            margin: 15px 0 30px 0;
            font-size: 32px;
            color: #222;
        }

        .btn-start {
            padding: 12px 30px;
            background-color: #2c2f7f;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
        }

            .btn-start:hover {
                background-color: #1f2266;
            }
    </style>
</head>
<body>

    <div class="card">
        <div class="icon">⚡</div>
        <h1>Electro<br />Billing</h1>

        <a href="/Billing/Register">
            <button type="button" class="btn-start">Get Started</button>
        </a>
    </div>

</body>
</html>