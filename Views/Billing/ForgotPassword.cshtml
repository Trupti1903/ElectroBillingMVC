@{
    ViewData["Title"] = "Forgot Password";
}
@{
    Layout = null;
}

<style>
    body {
        background: linear-gradient(to right,#162a45,#1f3c68);
        font-family: Arial, Helvetica, sans-serif;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .forgot-card {
        background: white;
        padding: 35px;
        border-radius: 12px;
        width: 360px;
        box-shadow: 0px 8px 20px rgba(0,0,0,0.2);
        text-align: center;
    }

        .forgot-card h2 {
            color: #162a45;
            margin-bottom: 25px;
        }

    .form-group {
        margin-bottom: 18px;
        text-align: left;
    }

    input[type="email"] {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 14px;
    }

        input[type="email"]:focus {
            outline: none;
            border-color: #162a45;
        }

    .send-btn {
        width: 100%;
        padding: 10px;
        border: none;
        background-color: #162a45;
        color: white;
        font-size: 15px;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.3s;
    }

        .send-btn:hover {
            background-color: #0f1c2e;
        }

    .message {
        margin-bottom: 15px;
        color: red;
        font-weight: 500;
    }
</style>

<div class="forgot-card">

    <h2>Forgot Password</h2>

    @if (ViewBag.Message != null)
    {
        <p class="message">@ViewBag.Message</p>
    }

    <form method="post">

        <div class="form-group">
            <input type="email" name="email" placeholder="Enter Admin Email" required />
        </div>

        <button type="submit" class="send-btn">Send Reset Link</button>

        <br /><br />

        <a href="/Billing/Login" class="login-btn">Back to Login</a>

    </form>

</div>