@model IEnumerable<ElectroBillingMVC.Models.Bill>

@{
    ViewData["Title"] = "Paid Payments";
}

<style>
    body {
        background: linear-gradient(to right, #1e2f44, #243b55);
    }

    .paid-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 85vh;
    }

    .paid-card {
        background: #f2f2f2;
        padding: 40px;
        border-radius: 15px;
        width: 850px;
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    }

        .paid-card h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #222;
        }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #2c3e50;
        color: white;
        padding: 12px;
        text-align: center;
    }

    td {
        padding: 12px;
        text-align: center;
        border: 1px solid #ccc;
        color: #333;
    }

    .delete-btn {
        background-color: #ff4d4d;
        color: white;
        padding: 6px 14px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }

        .delete-btn:hover {
            background-color: #e63939;
        }
</style>

<div class="paid-container">
    <div class="paid-card">
        <h2>Paid Payments</h2>

        <table>
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Mobile</th>
                    <th>Paid Amount</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <!-- Static UI Data -->
                <tr>
                    <td>Yashvi</td>
                    <td>1234567890</td>
                    <td>₹3000</td>
                    <td>2/11/2026</td>
                    <td>11:50:50 PM</td>
                    <td>
                        <button class="delete-btn">Delete</button>
                    </td>
                </tr>

                <tr>
                    <td>Yashvi</td>
                    <td>123456789</td>
                    <td>₹300</td>
                    <td>2/13/2026</td>
                    <td>5:14:31 PM</td>
                    <td>
                        <button class="delete-btn">Delete</button>
                    </td>
                </tr>

            </tbody>
        </table>
    </div>
</div>
