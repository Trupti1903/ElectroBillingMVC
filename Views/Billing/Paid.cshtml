@model IEnumerable<ElectroBillingMVC.Models.Bill>

@{
    ViewData["Title"] = "Paid Payments";
}

<style>
    body {
        background: linear-gradient(to right, #1e2f44, #243b55);
    }

    .paid-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 85vh;
    }

    .paid-card {
        background: #f2f2f2;
        padding: 40px;
        border-radius: 15px;
        width: 850px;
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    }

        .paid-card h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #222;
        }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #2c3e50;
        color: white;
        padding: 12px;
        text-align: center;
    }

    td {
        padding: 12px;
        text-align: center;
        border: 1px solid #ccc;
        color: #333;
    }

    .delete-btn {
        background-color: #ff4d4d;
        color: white;
        padding: 6px 14px;
        border: none;
        border-radius: 6px;
        text-decoration: none;
        cursor: pointer;
    }

        .delete-btn:hover {
            background-color: #e63939;
        }
</style>

<div class="paid-container">
    <div class="paid-card">
        <h2>Paid Payments</h2>

        <table>
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Mobile</th>
                    <th>Total</th>
                    <th>Paid</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var bill in Model)
                {
                    <tr>
                        <td>@bill.CustomerName</td>
                        <td>@bill.Phone</td>
                        <td>₹@bill.TotalAmount</td>
                        <td>₹@bill.PaidAmount</td>
                        <td>@bill.BillDate.ToString("dd/MM/yyyy")</td>
                        <td>@bill.BillDate.ToString("hh:mm tt")</td>
                        <td>
                            <form asp-action="DeleteBill" asp-controller="Billing" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@bill.BillId" />
                                <button type="submit" class="delete-btn">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>