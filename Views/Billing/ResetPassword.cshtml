@{
    ViewData["Title"] = "Reset Password";
}
@{
    Layout = null;
}


<style>
    body {
        background: linear-gradient(to right,#162a45,#1f3c68);
        font-family: Arial, Helvetica, sans-serif;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .reset-card {
        background: white;
        padding: 35px;
        border-radius: 12px;
        width: 350px;
        box-shadow: 0px 8px 20px rgba(0,0,0,0.2);
    }

        .reset-card h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #162a45;
        }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        font-weight: 600;
        display: block;
        margin-bottom: 6px;
    }

    input[type="password"] {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 14px;
    }

        input[type="password"]:focus {
            outline: none;
            border-color: #162a45;
        }

    .reset-btn {
        width: 100%;
        padding: 10px;
        border: none;
        background-color: #162a45;
        color: white;
        font-size: 15px;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.3s;
    }

        .reset-btn:hover {
            background-color: #0f1c2e;
        }

    .message {
        color: red;
        text-align: center;
        margin-bottom: 15px;
    }
</style>

<div class="reset-card">

    <h2>Reset Password</h2>

    @if (ViewBag.Message != null)
    {
        <p class="message">@ViewBag.Message</p>
    }

    <form method="post">

        <!-- Hidden Token -->
        <input type="hidden" name="token" value="@ViewBag.Token" />

        <div class="form-group">
            <label>New Password</label>
            <input type="password" name="newPassword" required />
        </div>

        <button type="submit" class="reset-btn">Reset Password</button>

    </form>

</div>