@model ElectroBillingMVC.Models.Bill

@{
    ViewData["Title"] = "Billing";
}

<style>
    body {
        background: linear-gradient(to right, #162a45);
    }

    .billing-card {
        background: #f4f4f4;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0px 8px 20px rgba(0,0,0,0.2);
    }

    .btn-primary {
        background-color: #2b2f77;
        border: none;
    }

        .btn-primary:hover {
            background-color: #1e225f;
        }

    .table thead {
        background-color: #2c3e50;
        color: white;
    }
</style>

<div class="container mt-5">
    <div class="billing-card mx-auto col-md-8">
        <h2 class="text-center mb-4">Billing</h2>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>

            <!-- Customer Details -->
            <h5>Customer Details</h5>
            <div class="row mb-3">
                <div class="col-md-4">
                    <input asp-for="CustomerName" class="form-control" placeholder="Customer Name" required />
                </div>
                <div class="col-md-4">
                    <input asp-for="Phone" class="form-control" placeholder="Mobile Number" required />
                </div>
                <div class="col-md-4">
                    <input asp-for="Address" class="form-control" placeholder="Address" required />
                </div>
            </div>

            <!-- Add Product -->
            <h5>Add Product</h5>
            <div class="row mb-3">
                <div class="col-md-4">
                    <input type="text" id="productName" class="form-control" placeholder="Product Name">
                </div>
                <div class="col-md-3">
                    <input type="number" id="price" class="form-control" placeholder="Price">
                </div>
                <div class="col-md-3">
                    <input type="number" id="qty" class="form-control" value="1">
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-primary w-100" onclick="addProduct()">Add</button>
                </div>
            </div>

            <!-- Product Table -->
            <table class="table table-bordered text-center">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody id="productTable"></tbody>
            </table>

            <!-- Hidden TotalAmount (Important) -->
            <input asp-for="TotalAmount" type="hidden" id="totalAmountHidden" name="TotalAmount" />
            <!-- Paid Amount -->
            <div class="row mb-3">
                <div class="col-md-6 offset-md-6">
                    <label>Paid Amount</label>
                    <input asp-for="PaidAmount" id="paidAmountInput" class="form-control" value="0" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100">Save Bill</button>

        </form>
    </div>
</div>

<script>
    let grandTotal = 0;

    function addProduct() {
        let name = document.getElementById("productName").value;
        let price = parseFloat(document.getElementById("price").value);
        let qty = parseInt(document.getElementById("qty").value);

        if (!name || !price || !qty) {
            alert("Please fill all product fields");
            return;
        }

        let total = price * qty;
        grandTotal += total;

        // Set hidden value for server
        document.getElementById("totalAmountHidden").value = grandTotal;

        let row = `<tr>
                        <td>${name}</td>
                        <td>${qty}</td>
                        <td>${price}</td>
                        <td>${total}</td>
                   </tr>`;

        document.getElementById("productTable").innerHTML += row;

        document.getElementById("productName").value = "";
        document.getElementById("price").value = "";
        document.getElementById("qty").value = 1;
    }
</script>